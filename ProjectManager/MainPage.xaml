<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectManager.MainPage">

    <ListView ItemsSource="{Binding Projects}" ItemTapped="ListView_ItemTapped">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Grid ColumnDefinitions="8*,*" RowDefinitions="*,*">
                        <Label Text="{Binding Title}" Grid.Column="0" Grid.Row="0"/>
                        <Label Text="{Binding Date}" Grid.Column="0" Grid.Row="1"/>
                        <Button Text="Odebrat" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"  BackgroundColor="Red" Clicked="DeleteButton_Clicked"/>
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>

</ContentPage>
